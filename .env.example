# Скопируйте этот файл в app/.env и заполните.
# TELEGRAM_TOKEN можно не дублировать — он подхватится из DC_Cargo/.env автоматически.

# Токен Telegram-бота (если нужен отдельный от старого bot.py)
# TELEGRAM_TOKEN=123456:ABC-DEF...

# PostgreSQL — та же БД, что и у CargoBot. Скопируй значение из CargoBot/.env
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Необязательно: канал для проверки подписки (пусто = не проверяем)
# CHANNEL_USERNAME=@your_channel
